<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('partials/head') %>
</head>
<body>
<%- include('partials/header') %>

<main id="main">
  <section class="page-hero reveal" data-reveal="mount">
    <div class="container">
      <p class="eyebrow">Contato</p>
      <h1><%= meta.h1 %></h1>
      <p class="page-hero__subhead">Orçamento sem compromisso pra SEO local, sites e Google Meu Negócio.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-grid__info reveal">
        <h2>Atendimento</h2>
        <p>
          Fale direto pelo WhatsApp — resposta rápida, sem formulário
          burocrático.
        </p>
        <a href="<%= business.whatsappUrl %>" class="btn btn--gold btn--lg" target="_blank" rel="noopener">Falar no WhatsApp</a>

        <dl class="contact-grid__details">
          <dt>Telefone / WhatsApp</dt>
          <dd><a href="tel:<%= business.phoneIntl %>"><%= business.phoneDisplay %></a></dd>
          <dt>E-mail</dt>
          <dd><a href="mailto:<%= business.email %>"><%= business.email %></a></dd>
          <dt>Instagram</dt>
          <dd><a href="<%= business.instagram %>" target="_blank" rel="noopener">@agenciakazuki</a></dd>
          <dt>Facebook</dt>
          <dd><a href="<%= business.facebook %>" target="_blank" rel="noopener">/AgenciaKazuki</a></dd>
        </dl>

        <h2>Onde estamos</h2>
        <address>
          <%= business.address.street %><br>
          <%= business.address.neighborhood %>, <%= business.address.city %>/<%= business.address.state %><br>
          CEP <%= business.address.zip %>
        </address>
      </div>

      <div class="contact-grid__map reveal" data-reveal-delay="120">
        <iframe
          title="Localização da Kazuki Marketing em Cotia/SP"
          src="https://www.google.com/maps?q=<%= business.geo.lat %>,<%= business.geo.lng %>&z=16&output=embed"
          width="100%"
          height="420"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<script src="/js/main.js" defer></script>
</body>
</html>
