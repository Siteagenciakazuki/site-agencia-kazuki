<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="theme-color" content="#0A0A0A">
<meta name="robots" content="<%= typeof meta.noindex !== 'undefined' && meta.noindex ? 'noindex, nofollow' : 'index, follow' %>">
<meta name="author" content="<%= business.name %>">

<title><%= meta.title %></title>
<meta name="description" content="<%= meta.description %>">
<link rel="canonical" href="<%= meta.canonical %>">

<!-- hreflang pt-BR -->
<link rel="alternate" hreflang="pt-BR" href="<%= meta.canonical %>">
<link rel="alternate" hreflang="x-default" href="<%= meta.canonical %>">

<!-- Geo tags — SEO local Cotia/SP -->
<meta name="geo.region" content="BR-SP">
<meta name="geo.placename" content="Cotia">
<meta name="geo.position" content="<%= business.geo.lat %>;<%= business.geo.lng %>">
<meta name="ICBM" content="<%= business.geo.lat %>, <%= business.geo.lng %>">

<!-- Open Graph -->
<meta property="og:type" content="<%= typeof meta.ogType !== 'undefined' ? meta.ogType : 'website' %>">
<meta property="og:title" content="<%= meta.title %>">
<meta property="og:description" content="<%= meta.description %>">
<meta property="og:url" content="<%= meta.canonical %>">
<meta property="og:image" content="<%= business.siteUrl %>/images/logo-kazuki-marketing.png">
<meta property="og:image:width" content="800">
<meta property="og:image:height" content="800">
<meta property="og:locale" content="pt_BR">
<meta property="og:site_name" content="<%= business.name %>">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= meta.title %>">
<meta name="twitter:description" content="<%= meta.description %>">
<meta name="twitter:image" content="<%= business.siteUrl %>/images/logo-kazuki-marketing.png">

<!-- Breadcrumb Schema — páginas internas -->
<% if (meta.breadcrumb) { %>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": meta.breadcrumb.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": `${business.siteUrl}${item.path}`
  }))
}) %>
</script>
<% } %>

<!-- Article Schema — posts do blog -->
<% if (typeof post !== 'undefined' && post) { %>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.excerpt,
  "datePublished": post.date,
  "author": { "@type": "Person", "name": business.founder },
  "publisher": { "@type": "Organization", "name": business.name, "url": business.siteUrl },
  "mainEntityOfPage": { "@type": "WebPage", "@id": meta.canonical }
}) %>
</script>
<% } %>

<!-- Schema.org LocalBusiness — presente em todas as páginas -->
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "image": `${business.siteUrl}/images/logo-kazuki-marketing.png`,
  "telephone": business.phoneIntl,
  "email": business.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": business.address.street,
    "addressLocality": business.address.city,
    "addressRegion": business.address.state,
    "postalCode": business.address.zip,
    "addressCountry": business.address.country
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": business.geo.lat,
    "longitude": business.geo.lng
  },
  "url": business.siteUrl,
  "areaServed": "Cotia, SP",
  "sameAs": [business.instagram, business.facebook]
}) %>
</script>

<!-- FAQPage Schema — apenas na home -->
<% if (typeof faq !== "undefined" && faq && faq.length) { %>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer }
  }))
}) %>
</script>
<% } %>

<link rel="icon" href="/images/favicon-kazuki.png" type="image/png">
<link rel="apple-touch-icon" href="/images/favicon-kazuki.png">

<!-- Preload hero image (LCP) — só na home -->
<% if (currentPath === "/") { %>
<link rel="preload" as="image" href="/images/alexandre-santos-seo-local-cotia.png" fetchpriority="high">
<% } %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/style.css">
