<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__col">
      <img src="/images/logo-kazuki-marketing.png" alt="Logo Kazuki Marketing" title="Kazuki Marketing" width="56" height="56">
      <p class="site-footer__tagline"><%= business.tagline %></p>
      <p class="site-footer__desc">Agência de marketing digital especializada em SEO local em Cotia/SP.</p>
    </div>

    <div class="site-footer__col">
      <h2 class="site-footer__heading">Links rápidos</h2>
      <ul class="site-footer__links">
        <% navLinks.forEach((link) => { %>
          <li><a href="<%= link.href %>"><%= link.label %></a></li>
        <% }) %>
      </ul>
    </div>

    <div class="site-footer__col">
      <h2 class="site-footer__heading">Contato</h2>
      <address class="site-footer__address">
        <%= business.name %><br>
        <%= business.address.street %><br>
        <%= business.address.neighborhood %>, <%= business.address.city %>/<%= business.address.state %> — CEP <%= business.address.zip %><br>
        <a href="tel:<%= business.phoneIntl %>"><%= business.phoneDisplay %></a>
      </address>
      <ul class="site-footer__social">
        <li><a href="<%= business.instagram %>" target="_blank" rel="noopener">Instagram</a></li>
        <li><a href="<%= business.facebook %>" target="_blank" rel="noopener">Facebook</a></li>
      </ul>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <ul class="site-footer__policies">
      <li><a href="/privacidade">Política de Privacidade</a></li>
      <li><a href="/termos">Termos de Uso</a></li>
      <li><a href="/cookies">Política de Cookies</a></li>
    </ul>
    <p class="site-footer__legal">&copy; <%= year %> <%= business.name %> · CNPJ <%= business.cnpj %></p>
  </div>
</footer>

<a href="<%= business.whatsappUrl %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="Falar no WhatsApp">
