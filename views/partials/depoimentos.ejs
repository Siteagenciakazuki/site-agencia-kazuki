const msgs = [
  { de: "CH", cor: "#FF4500", nome: "Carlos · Mama Mia", texto: "Pizzaria tá no topo Google! 🍕🎉", hora: "10:42", novo: true },
  { de: "AP", cor: "#E91E8C", nome: "Ana Paula · Rancho do Sol", texto: "Casa cheia todo fds!! Obg Kazuki 🥩🔥", hora: "14:17", novo: true },
  { de: "MT", cor: "#1E90FF", nome: "Márcio · Sushi Sashimi", texto: "Top 3 Google Maps já!! 🍣🚀", hora: "15:02", novo: false },
  { de: "LF", cor: "#2ECC40", nome: "Luciana · Burger Mania", texto: "Ficha otimizada, clientes chegando 👍🍔", hora: "18:33", novo: true },
  { de: "RA", cor: "#9B59B6", nome: "Roberto · Cantina Nonno", texto: "1º lugar no Maps hoje!! 😭🍝", hora: "20:11", novo: true },
