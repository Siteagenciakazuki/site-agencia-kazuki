<%
const deps = [
  {
    nome: "Carlos Henrique", restaurante: "Pizzaria Mama Mia", cidade: "SP",
    inicial: "CH", cor: "#FF4500",
    mensagem: "E aí, pessoal da Kazuki! 🎉 Só passando pra dizer q a pizzaria tá bombando depois daquele trampo no Google! Meus clientes sempre tão falando q acharam a Mama Mia lá. Valeu demais! 🍕🙌",
    resultado: "+40% clientes", estrelas: 5, hora: "10:42",
    review: "Melhor investimento que fiz pro meu restaurante. Aparecemos no topo do Google em 2 meses!"
  },
  {
    nome: "Ana Paula", restaurante: "Churrascaria Fogo no Chão", cidade: "RJ",
    inicial: "AP", cor: "#E91E8C",
    mensagem: "Gente, tô mto feliz!! Desde q vcs otimizaram nosso perfil no Google Meu Negócio, o movimento só cresce. A casa tá cheia todo fds! Vocês são feras 🤩🥩",
    resultado: "+50% fds", estrelas: 5, hora: "14:17",
    review: "Minha churrascaria aparece no Maps antes da concorrência agora. Os resultados foram rápidos!"
  },
  {
    nome: "Márcio Tanaka", restaurante: "Sushi Sashimi", cidade: "CWB",
    inicial: "MT", cor: "#1E90FF",
    mensagem: "Fala, pessoal da Kazuki! 🚀 O Sushi Sashimi apareceu no topo do Google! Cada vez mais gente pedindo 🍣. Muito obrigado por toda ajuda e suporte! 😄",
    resultado: "Top 3 Google", estrelas: 5, hora: "09:05",
    review: "Ficha do Google ficou perfeita, avaliações aumentaram, deliverys também. Recomendo!"
  },
  {
    nome: "Luciana Ferreira", restaurante: "Burger Mania", cidade: "BH",
    inicial: "LF", cor: "#2ECC40",
    mensagem: "Oi equipe Kazuki! 😃 Passei pra agradecer o boost na nossa visibilidade! A ficha do Burger Mania tá linda e cheia de comentários agora. Sentimos o aumento de clientes tb 👍🍔",
    resultado: "Ficha 100%", estrelas: 5, hora: "18:33",
    review: "Da visibilidade zero pra aparecer em todo Google Maps da região. Trabalho sério e com resultado."
  }
];
%>

<section class="section depoimentos" id="depoimentos">
  <div class="container">
    <p class="eyebrow reveal">Prova social</p>
    <h2 class="reveal">Resultados reais de clientes reais</h2>
    <p class="reveal" style="max-width:55ch;margin-bottom:var(--space-5)">
      Restaurantes que apareceram no topo do Google em Cotia e região depois de trabalhar com a Kazuki Marketing.
    </p>

    <div class="dep-grid">

      <!-- iPhone 17 Pro Max mockup com WhatsApp -->
      <div class="iphone-wrap reveal">
        <div class="iphone">
          <div class="iphone__island"></div>
          <div class="iphone__screen">
            <!-- WhatsApp header -->
            <div class="wa-header">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"/></svg>
              <span class="wa-header__title">Kazuki Marketing</span>
              <div class="wa-header__icons">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              </div>
            </div>

            <!-- lista de chats -->
            <div class="wa-list">
              <% deps.forEach((d, i) => { %>
              <div class="wa-item reveal" data-reveal-delay="<%= i * 80 %>">
                <div class="wa-avatar" style="background:<%= d.cor %>"><%= d.inicial %></div>
                <div class="wa-info">
                  <div class="wa-info__top">
                    <span class="wa-name"><%= d.nome %></span>
                    <span class="wa-time"><%= d.hora %></span>
                  </div>
                  <div class="wa-info__bottom">
                    <span class="wa-preview"><%= d.mensagem.substring(0, 42) %>…</span>
                    <span class="wa-badge">1</span>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
          <div class="iphone__bar"></div>
        </div>
        <!-- badge de resultado flutuante -->
        <div class="iphone-badge reveal" data-reveal-delay="300">
          <span>💬</span> 4 clientes satisfeitos
        </div>
      </div>

      <!-- mensagens expandidas -->
      <div class="dep-msgs">
        <% deps.forEach((d, i) => { %>
        <div class="dep-msg reveal" data-reveal-delay="<%= i * 70 %>">
          <div class="dep-msg__top">
            <div class="dep-avatar" style="background:<%= d.cor %>"><%= d.inicial %></div>
            <div>
              <strong><%= d.nome %></strong>
              <span class="dep-rest"><%= d.restaurante %></span>
            </div>
            <span class="dep-tag"><%= d.resultado %></span>
          </div>
          <div class="dep-bubble">
            <%= d.mensagem %>
            <span class="dep-bubble__time"><%= d.hora %> <svg width="14" height="10" viewBox="0 0 14 10" fill="#53bdeb" aria-hidden="true"><path d="M1 5l3 3 5-6M6 7.5l2 2 5-6"/></svg></span>
          </div>
        </div>
        <% }) %>
      </div>

    </div><!-- /dep-grid -->

    <!-- Google Reviews -->
    <h2 class="reveal" style="margin-top:var(--space-6)">O que dizem no Google</h2>
    <div class="google-reviews">
      <% deps.forEach((d, i) => { %>
      <article class="g-review reveal" data-reveal-delay="<%= i * 60 %>">
        <div class="g-review__top">
          <div class="dep-avatar" style="background:<%= d.cor %>; width:38px;height:38px;font-size:.9rem"><%= d.inicial %></div>
          <div>
            <strong class="g-review__name"><%= d.nome %></strong>
            <div class="g-stars" aria-label="5 estrelas">
              <% for(let s=0;s<5;s++) { %><svg width="14" height="14" viewBox="0 0 24 24" fill="#FBBC04" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg><% } %>
            </div>
          </div>
          <!-- G Google logo -->
          <svg class="g-logo" viewBox="0 0 24 24" width="22" height="22" aria-label="Google"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        </div>
        <p class="g-review__text"><%= d.review %></p>
        <span class="g-review__rest"><%= d.restaurante %> · <%= d.cidade %></span>
      </article>
      <% }) %>
    </div>

    <!-- GMB Profile Card -->
    <div class="gmb-card reveal" style="margin-top:var(--space-5)">
      <div class="gmb-card__photo">
        <img src="/images/restaurante-gmb.jpg" alt="Restaurante brasileiro bem otimizado no Google Meu Negócio" width="400" height="300" loading="lazy">
      </div>
      <div class="gmb-card__info">
        <div class="gmb-card__brand">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-label="Google"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          <span>Google Meu Negócio</span>
        </div>
        <h3>Churrascaria Fogo no Chão</h3>
        <div class="gmb-rating">
          <span class="gmb-rating__num">4,9</span>
          <div class="g-stars">
            <% for(let s=0;s<5;s++) { %><svg width="16" height="16" viewBox="0 0 24 24" fill="#FBBC04" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg><% } %>
          </div>
          <span class="gmb-rating__count">247 avaliações</span>
        </div>
        <p class="gmb-status"><span class="gmb-open">● Aberto agora</span> · Fecha às 23h</p>
        <ul class="gmb-attrs">
          <li>🍖 Churrasco · Rodízio</li>
          <li>📍 Centro, Cotia/SP</li>
          <li>🌐 Delivery · Reservas</li>
        </ul>
        <div class="gmb-score">
          <div class="gmb-score__bar">
            <div class="gmb-score__fill" style="width:90%"></div>
          </div>
          <span class="gmb-score__label">GBP Score <strong>90/100</strong> ✓</span>
        </div>
      </div>
    </div>

  </div>
</section>
